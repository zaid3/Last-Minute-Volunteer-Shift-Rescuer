# Public base URL of the deployed app (used to build claim links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase (server-side only - never expose the service role key to the browser)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Resend
RESEND_API_KEY=
EMAIL_FROM="Shift Rescuer <alerts@yourcharity.org>"

# Shared secret required in the x-manager-key header for /api/broadcast
MANAGER_API_KEY=
