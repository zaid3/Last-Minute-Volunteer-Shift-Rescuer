# Public base URL of the deployed app, used to build volunteer claim links.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase. Keep the service role key on the server only.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Resend transactional email.
RESEND_API_KEY=
EMAIL_FROM="Shift Rescuer <alerts@yourcharity.org>"
COORDINATOR_EMAIL=

# Coordinator access for the first single-organisation release.
# Use a long unique password and a separate random session secret.
COORDINATOR_PASSWORD=
MANAGER_SESSION_SECRET=

# Optional machine-to-machine access for POST /api/broadcast.
MANAGER_API_KEY=
